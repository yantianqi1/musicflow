# ============================================================
# MusicFlow 环境变量示例 —— 复制为 .env 后填入真实值
# ============================================================

# ---------- MiniMax API ----------
# 用于音乐/歌词/语音/声音克隆全部能力
# 申请地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ---------- JWT ----------
# 生产环境请改成随机长字符串 (e.g. `openssl rand -hex 32`)
SECRET_KEY=change-me-in-production-please

# ---------- 数据库 ----------
# 默认 SQLite (自动创建于 ./data/musicflow.db)
# 如需 PostgreSQL: postgresql+asyncpg://user:pass@host:5432/musicflow
DATABASE_URL=sqlite+aiosqlite:///./data/musicflow.db

# ---------- LLM (OpenAI 兼容接口) ----------
# Agent 对话 & 工具调用使用的大模型
# 兼容 DeepSeek / OpenAI / Gemini代理 / Ollama / vLLM 等
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
